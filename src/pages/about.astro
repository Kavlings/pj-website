---
import Layout from "../layouts/Layout.astro"
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro"
import CTA from "../components/CTA.astro";
---

<Layout title="About Us - PJ Marketing Solutions" description="Founded in 2014, PJ Marketing Solutions helps exhibition and event organisers grow through targeted B2B data, televerification, and hosted buyer programmes. Over 1,000 projects completed.">
    <section class="page-hero">
        <Navigation />
        <div class="hero-overlay">
            <h1>Where Businesses Turn for Reliable Data</h1>
            <!-- <p>Where Businesses Turn for Reliable Data</p> -->
            <!-- <p>Whether you need to fill your pipeline with sales-qualified leads, refine your data for smarter targeting, or engage decision-makers before your next major event, we’re here to make it happen.</p> -->
        </div>
    </section>

    <section class="about-intro">
        <div class="container">
            <p>Whether you need to fill your pipeline with sales-qualified leads, refine your data for smarter targeting, or engage decision-makers before your next major event, we’re here to make it happen.</p>
            <h2>Who we are </h2>
            <p>Founded in 2014 by a team with decades of hands-on exhibition experience, PJ Marketing Solutions was created to help companies to maximize their potential. We deliver B2B data, insights, telemarketing, and sales development results for international organisations.</p>
            <p>Our results speak for themselves.</p>
        </div>
    </section>

    <section class="stats-section">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <h3>10+</h3>
                    <p>Years of Experience</p>
                </div>
                <div class="stat-item">
                    <h3>1000+</h3>
                    <p>Projects Completed</p>
                </div>
                <div class="stat-item">
                    <h3>50+</h3>
                    <p>Event Partners</p>
                </div>
                <div class="stat-item">
                    <h3>75%</h3>
                    <p>Clients remain engaged after 1 year</p>
                </div>
            </div>
        </div>
    </section>

    <CTA />
    <Footer slot="footer"/>
</Layout>

<style>

    .page-hero {
        position: relative;
        min-height: 60vh;
        width: 100%;
        overflow: hidden;
        background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
        display: flex;
        align-items: center;
        color: white;
        text-align: center;
        padding-top: 5rem;
        justify-content: center;
    }

    .hero-overlay h1 {
        font-size: 3rem;
        font-weight: 300;
        margin-bottom: 0.75rem;
        line-height: 1.2;

    }

    .hero-overlay p {
        font-size: 1.25rem;
        font-weight: 300;
        opacity: 0.9;
        max-width: 600px;
        margin: 0 auto;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .about-intro {
        padding: var(--section-y) 0;
        background-color: var(--color-bg);
    }

    .about-intro h2 {
        font-size: 2.5rem;
        font-weight: 300;
        margin-bottom: 2rem;
        color: var(--color-primary);
        text-align: center;
    }

    .about-intro p {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #333;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    /* Stats Section */
    .stats-section {
        padding: var(--section-y) 0;
        background: #fff;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2,minmax(0,1fr));
        gap: 1rem;
    }

    .stat-item {
        background: var(--color-bg-card);
        border: 1px solid rgba(22, 62, 147, 0.08);
        border-radius: 12px;
        padding: 1.25rem;
        text-align: center;
    }

    .stat-item p {
        margin: 0;
        font-size: 0.95rem;
        color: #444;
    }

    @media (min-width: 768px) {
        .stats-grid {
            grid-template-columns: repeat(4, minmax(0,1fr));
            gap: 1rem;
        }
    }
    
</style>


