---
export interface Props {
    title: string;
    description: string;
    ogImage?: string;
}

const { title, description, ogImage = '/logos/minimal-pj-logo.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://pjmarketing.ae');
const ogImageURL = new URL(ogImage, 'https://pjmarketing.ae');
---


<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />

        <!-- Twitter / LinkedIn card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
        <link rel="icon" href="/favicon.jpg" type="image/jpeg">
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "PJ Marketing Solutions",
            "legalName": "PJ Marketing Solutions FZ LLE",
            "url": "https://pjmarketing.ae",
            "logo": "https://pjmarketing.ae/logos/minimal-pj-logo.jpg",
            "foundingDate": "2014",
            "description": "B2B exhibition and event marketing agency based in Dubai, UAE. Specialists in data enrichment, televerification, email marketing, hosted buyer programmes, and on-site registration.",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Dubai",
                "addressCountry": "AE"
            },
            "contactPoint": {
                "@type": "ContactPoint",
                "email": "info@pjmarketing.ae",
                "contactType": "customer service"
            },
            "sameAs": [
                "https://www.linkedin.com/company/pj-marketing-solutions-fz-lle/"
            ],
            "areaServed": "Middle East",
            "hasOfferCatalog": {
                "@type": "OfferCatalog",
                "name": "Exhibition Marketing Services",
                "itemListElement": [
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Data Enrichment"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Televerification"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Email Marketing"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Hosted Buyer Programme"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "On-site Registration"}}
                ]
            }
        }
        </script>
    </head>
    <body>

        <div class="page-container">
            <main class="main-content">
                <slot />
            </main>
            <footer class="footer-sticky">
                <slot name="footer" />
            </footer>
        </div>

        <script>
            document.documentElement.classList.add('js-animate');
            const io = new IntersectionObserver(
                entries => entries.forEach(e => {
                    if (e.isIntersecting) {
                        e.target.classList.add('in-view');
                        io.unobserve(e.target);
                    }
                }),
                { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
            );
            document.querySelectorAll('[data-animate]').forEach(el => io.observe(el));
        </script>
    </body>
</html>


<style>
    :root {
        /* Colors */
        --color-primary: #163E93;
        --color-primary-hover: #1e4ba8;
        --color-dark: #051C2A;
        --color-bg: #f8f9fa;
        --color-bg-card: #f3f6fc;
        --color-text: #333;
        --color-text-muted: #444;
        --color-text-light: #666;

        /* Spacing scale */
        --space-xs: 0.5rem;
        --space-sm: 1rem;
        --space-md: 1.5rem;
        --space-lg: 2rem;
        --space-xl: 3rem;
        --space-2xl: 4rem;

        /* Section defaults */
        --section-x: 2rem;
        --section-y: 4rem;

        /* Border radius */
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
        --radius-xl: 16px;
    }

    /* Reset and base styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: "Inter", sans-serif;
        font-weight: 200;
        font-optical-sizing: auto;
        font-style: normal;
        line-height: 1.6;
        color: var(--color-text);
    }

    .page-container {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .main-content {
        flex: 1;
    }

    .footer-sticky {
        margin-top: auto;
    }

    @media (min-width: 768px) {
        h1 { font-size: 4rem; }
        h2 { font-size: 2.5rem; }
        p  { font-size: 1.5rem; }
        section { padding: var(--space-xl) var(--section-x); }
    }
</style>

<style is:global>
    /* Scroll reveal — only active when JS has loaded */
    html.js-animate [data-animate] {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.6s ease, transform 0.6s ease;
        transition-delay: var(--animate-delay, 0s);
    }
    html.js-animate [data-animate].in-view {
        opacity: 1;
        transform: translateY(0);
    }
</style>