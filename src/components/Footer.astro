---
const year = new Date().getFullYear();
---
<footer class="footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <span class="brand-name">PJ Marketing Solutions</span>
            <p>Data-driven exhibition marketing for B2B event organisers across the Middle East.</p>
        </div>

        <div class="footer-column">
            <h3>Company</h3>
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/services">Services</a>
            <a href="/contact">Contact</a>
        </div>

        <div class="footer-column">
            <h3>Contact</h3>
            <a href="mailto:info@pjmarketing.ae">info@pjmarketing.ae</a>
            <span class="location">Dubai, UAE</span>
            <a href="https://www.linkedin.com/company/pj-marketing-solutions-fz-lle/posts/?feedView=all" target="_blank" rel="noopener noreferrer" class="linkedin-link">
                <svg style="width:18px;height:18px;flex-shrink:0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.448-2.136 2.944v5.662H9.351V9h3.414v1.561h.048c.476-.9 1.637-1.852 3.368-1.852 3.6 0 4.263 2.37 4.263 5.452v6.291zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.114 20.452H3.56V9h3.554v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
                </svg>
                LinkedIn
            </a>
        </div>
    </div>

    <div class="footer-bottom">
        <p>© 2014–{year} PJ Marketing Solutions FZ LLE. All rights reserved.</p>
    </div>
</footer>

<style>
    .footer {
        background-color: #163E93;
        color: white;
    }

    .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .footer-brand .brand-name {
        display: block;
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .footer-brand p {
        font-size: 0.875rem;
        opacity: 0.75;
        max-width: 28ch;
        line-height: 1.6;
        margin: 0;
    }

    .footer-column {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .footer-column h3 {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.5;
        margin: 0 0 0.5rem 0;
    }

    a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.4rem;
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.875rem;
        color: white;
        opacity: 0.85;
        transition: opacity 0.2s ease, background-color 0.2s ease;
    }

    a:hover {
        opacity: 1;
        background-color: rgba(255, 255, 255, 0.1);
    }

    a:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 2px;
    }

    .location {
        padding: 0.3rem 0.4rem;
        font-size: 0.875rem;
        opacity: 0.85;
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        padding: 1.25rem 2rem;
        text-align: center;
    }

    .footer-bottom p {
        font-size: 0.8rem;
        opacity: 0.5;
        margin: 0;
    }

    @media (min-width: 768px) {
        .footer-inner {
            grid-template-columns: 2fr 1fr 1fr;
            gap: 3rem;
        }
    }
</style>
